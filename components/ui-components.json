{
  "component_library": {
    "landing_hero": {
      "structure": "flex flex-col items-center justify-center min-h-screen relative overflow-hidden",
      "background": "bg-gradient-to-br from-[#0A0A0F] via-[#1A1A2E] to-[#0A0A0F]",
      "3d_laptop": {
        "position": "absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2",
        "animation": "animate-float",
        "glow": "drop-shadow-[0_0_30px_rgba(79,209,197,0.4)]"
      },
      "headline": {
        "typography": "text-6xl font-bold bg-gradient-to-r from-[#4FD1C5] to-[#F687B3] bg-clip-text text-transparent",
        "animation": "animate-fade-in-up"
      },
      "cta_button": {
        "base": "px-8 py-4 bg-gradient-to-r from-[#4FD1C5] to-[#F687B3] rounded-2xl font-semibold text-white",
        "hover": "hover:scale-105 hover:shadow-[0_0_30px_rgba(79,209,197,0.5)] transition-all duration-300",
        "3d": "transform-gpu hover:translateZ-2"
      }
    },
    "feature_cards": {
      "container": "grid grid-cols-1 md:grid-cols-3 gap-8 px-8",
      "card": {
        "base": "p-8 bg-[#1A1A2E]/80 backdrop-blur-xl rounded-3xl border border-[#4FD1C5]/20",
        "hover": "hover:-translate-y-2 hover:rotate-1 hover:shadow-[0_20px_40px_rgba(79,209,197,0.2)]",
        "transition": "transition-all duration-500 ease-out"
      },
      "icon": {
        "size": "w-16 h-16",
        "glow": "drop-shadow-[0_0_20px_rgba(79,209,197,0.6)]",
        "animation": "animate-pulse"
      }
    },
    "pricing_cards": {
      "container": "grid grid-cols-1 md:grid-cols-3 gap-8 px-8",
      "card": {
        "base": "p-8 bg-[#1A1A2E]/60 backdrop-blur-2xl rounded-3xl border",
        "free": "border-[#4FD1C5]/30 hover:border-[#4FD1C5] hover:shadow-[0_0_40px_rgba(79,209,197,0.3)]",
        "pro": "border-[#F687B3]/30 hover:border-[#F687B3] hover:shadow-[0_0_40px_rgba(246,135,179,0.3)] scale-105",
        "team": "border-[#FFD700]/30 hover:border-[#FFD700] hover:shadow-[0_0_40px_rgba(255,215,0,0.3)]"
      },
      "popular_badge": {
        "position": "absolute -top-4 left-1/2 transform -translate-x-1/2",
        "style": "px-4 py-2 bg-gradient-to-r from-[#F687B3] to-[#4FD1C5] rounded-full text-sm font-bold",
        "glow": "shadow-[0_0_20px_rgba(246,135,179,0.5)]"
      }
    },
    "dashboard_sidebar": {
      "container": "w-80 h-screen bg-[#1A1A2E]/90 backdrop-blur-xl border-r border-[#4FD1C5]/20 p-6",
      "nav_item": {
        "base": "flex items-center space-x-4 p-4 rounded-2xl transition-all duration-300",
        "inactive": "text-[#B8BCC8] hover:bg-[#4FD1C5]/10 hover:text-[#4FD1C5]",
        "active": "bg-gradient-to-r from-[#4FD1C5]/20 to-[#F687B3]/20 text-[#4FD1C5] shadow-[0_0_20px_rgba(79,209,197,0.3)]"
      },
      "active_indicator": {
        "position": "absolute left-0 w-1 h-full bg-gradient-to-b from-[#4FD1C5] to-[#F687B3]",
        "animation": "animate-pulse"
      }
    },
    "input_card": {
      "container": "p-8 bg-[#1A1A2E]/80 backdrop-blur-xl rounded-3xl border border-[#4FD1C5]/30",
      "3d_effect": "transform-gpu hover:translateZ-4 hover:-translate-y-2",
      "glow": "hover:shadow-[0_20px_60px_rgba(79,209,197,0.2)]",
      "input": {
        "base": "w-full p-4 bg-[#0A0A0F]/50 border border-[#4FD1C5]/20 rounded-2xl text-white placeholder-[#6B7280]",
        "focus": "focus:border-[#4FD1C5] focus:shadow-[0_0_20px_rgba(79,209,197,0.3)] focus:outline-none"
      }
    },
    "summary_card": {
      "container": "relative w-full h-96 perspective-1000",
      "card_inner": "relative w-full h-full transition-transform duration-700 transform-style-preserve-3d",
      "flipped": "rotate-y-180",
      "front": "absolute inset-0 w-full h-full backface-hidden bg-[#1A1A2E]/80 backdrop-blur-xl rounded-3xl p-8",
      "back": "absolute inset-0 w-full h-full backface-hidden rotate-y-180 bg-[#16213E]/80 backdrop-blur-xl rounded-3xl p-8"
    },
    "loading_animation": {
      "container": "flex items-center justify-center space-x-2",
      "particle": "w-3 h-3 bg-[#4FD1C5] rounded-full animate-bounce",
      "progress_bar": {
        "base": "w-full h-2 bg-[#1A1A2E] rounded-full overflow-hidden",
        "fill": "h-full bg-gradient-to-r from-[#4FD1C5] to-[#F687B3] animate-pulse"
      }
    },
    "action_buttons": {
      "container": "flex space-x-4",
      "button": {
        "base": "flex items-center space-x-2 px-6 py-3 bg-[#1A1A2E]/60 backdrop-blur-xl rounded-2xl border transition-all duration-300",
        "pdf": "border-[#4FD1C5]/30 hover:border-[#4FD1C5] hover:shadow-[0_0_20px_rgba(79,209,197,0.4)]",
        "whatsapp": "border-[#F687B3]/30 hover:border-[#F687B3] hover:shadow-[0_0_20px_rgba(246,135,179,0.4)]",
        "notion": "border-[#FFD700]/30 hover:border-[#FFD700] hover:shadow-[0_0_20px_rgba(255,215,0,0.4)]"
      }
    }
  },
  "animations": {
    "keyframes": {
      "float": {
        "0%, 100%": "transform: translateY(0px)",
        "50%": "transform: translateY(-20px)"
      },
      "fade-in-up": {
        "0%": "opacity: 0, transform: translateY(30px)",
        "100%": "opacity: 1, transform: translateY(0)"
      },
      "glow-pulse": {
        "0%, 100%": "box-shadow: 0 0 20px rgba(79,209,197,0.3)",
        "50%": "box-shadow: 0 0 40px rgba(79,209,197,0.6)"
      }
    },
    "classes": {
      "animate-float": "animation: float 6s ease-in-out infinite",
      "animate-fade-in-up": "animation: fade-in-up 1s ease-out",
      "animate-glow-pulse": "animation: glow-pulse 2s ease-in-out infinite"
    }
  },
  "three_js_components": {
    "floating_laptop": {
      "geometry": "BoxGeometry(2, 1.2, 0.1)",
      "material": "MeshStandardMaterial({ color: '#1A1A2E', metalness: 0.8, roughness: 0.2 })",
      "animation": "rotation.y += 0.01, position.y = Math.sin(time) * 0.2"
    },
    "particle_system": {
      "count": 100,
      "geometry": "SphereGeometry(0.02)",
      "material": "PointsMaterial({ color: '#4FD1C5', size: 0.1 })",
      "animation": "random_float_movement"
    },
    "neon_orbs": {
      "geometry": "SphereGeometry(0.5)",
      "material": "MeshBasicMaterial({ color: '#4FD1C5', transparent: true, opacity: 0.6 })",
      "glow_effect": "bloom_pass"
    }
  }
}